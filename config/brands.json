{
  "brands": [
    {
      "id": "openai",
      "name": "OpenAI",
      "keywords": [
        "\"OpenAI\"",
        "\"ChatGPT\"",
        "\"OpenAI API\""
      ],
      "core_terms": [
        "openai",
        "chatgpt"
      ],
      "products": [
        {
          "name": "ChatGPT",
          "patterns": ["chatgpt"]
        },
        {
          "name": "OpenAI API",
          "patterns": ["openai api", "responses api", "assistants api"]
        },
        {
          "name": "Sora",
          "patterns": ["sora"]
        }
      ],
      "exclude_patterns": [
        "openai.com",
        "help.openai.com",
        "platform.openai.com"
      ]
    },
    {
      "id": "github",
      "name": "GitHub",
      "keywords": [
        "\"GitHub\"",
        "\"GitHub Copilot\"",
        "\"GitHub Actions\""
      ],
      "core_terms": [
        "github",
        "copilot"
      ],
      "products": [
        {
          "name": "GitHub Copilot",
          "patterns": ["github copilot", "copilot"]
        },
        {
          "name": "GitHub Actions",
          "patterns": ["github actions", "actions workflow"]
        },
        {
          "name": "GitHub Pages",
          "patterns": ["github pages"]
        }
      ],
      "exclude_patterns": [
        "github.com",
        "docs.github.com"
      ]
    },
    {
      "id": "vercel",
      "name": "Vercel",
      "keywords": [
        "\"Vercel\"",
        "\"Next.js\"",
        "\"Vercel AI SDK\""
      ],
      "core_terms": [
        "vercel",
        "next.js",
        "nextjs"
      ],
      "products": [
        {
          "name": "Next.js",
          "patterns": ["next.js", "nextjs"]
        },
        {
          "name": "Vercel AI SDK",
          "patterns": ["vercel ai sdk", "ai sdk"]
        },
        {
          "name": "Vercel Platform",
          "patterns": ["vercel platform", "vercel functions"]
        }
      ],
      "exclude_patterns": [
        "vercel.com",
        "nextjs.org"
      ]
    }
  ],
  "scan_settings": {
    "lookback_days": 7,
    "signal_threshold": 40,
    "notify_threshold": 55,
    "max_results_per_keyword": 20
  }
}
